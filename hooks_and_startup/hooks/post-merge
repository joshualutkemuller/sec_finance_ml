#!/usr/bin/env bash
# =============================================================================
# post-merge hook — runs after `git pull` or a merge completes
# Auto-reinstalls requirements.txt for any project whose deps changed.
# =============================================================================
set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "── post-merge hook ──────────────────────────────────────────"

PROJECTS=(
    "01_lending_rate_anomaly"
    "02_collateral_optimizer"
    "03_portfolio_risk_monitor"
    "04_short_squeeze_scorer"
    "05_financing_cost_forecaster"
    "securities_lending_optimizer"
)

# Files changed in the merge
CHANGED=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null || true)

REINSTALLED=0
for PROJECT in "${PROJECTS[@]}"; do
    if echo "$CHANGED" | grep -q "^${PROJECT}/requirements.txt"; then
        echo -e "${YELLOW}⚠ requirements.txt changed in ${PROJECT} — reinstalling...${NC}"
        if [ -d ".venv" ]; then
            .venv/bin/pip install -q -r "${PROJECT}/requirements.txt"
        else
            pip install -q -r "${PROJECT}/requirements.txt"
        fi
        echo -e "${GREEN}✓ Reinstalled ${PROJECT}/requirements.txt${NC}"
        REINSTALLED=1
    fi
done

if [ "$REINSTALLED" -eq 0 ]; then
    echo -e "${GREEN}✓ No requirements.txt files changed — nothing to reinstall${NC}"
fi

echo -e "${GREEN}── post-merge complete ──────────────────────────────────────${NC}"
exit 0
