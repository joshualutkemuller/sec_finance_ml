#!/usr/bin/env bash
# =============================================================================
# pre-push hook — runs on every `git push`
# Runs pytest for each project that has changed files on the branch.
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "── pre-push hook ────────────────────────────────────────────"

PROJECTS=(
    "01_lending_rate_anomaly"
    "02_collateral_optimizer"
    "03_portfolio_risk_monitor"
    "04_short_squeeze_scorer"
    "05_financing_cost_forecaster"
)

# Determine files changed vs. the remote branch (or all staged if new branch)
REMOTE="$1"
REMOTE_BRANCH="$2"

CHANGED_FILES=""
if git rev-parse --verify "$REMOTE_BRANCH" &>/dev/null 2>&1; then
    CHANGED_FILES=$(git diff --name-only "$REMOTE_BRANCH"...HEAD 2>/dev/null || true)
else
    # New branch — compare to main
    CHANGED_FILES=$(git diff --name-only main...HEAD 2>/dev/null || git diff --name-only HEAD~1...HEAD 2>/dev/null || true)
fi

FAILED=0
for PROJECT in "${PROJECTS[@]}"; do
    # Check if any file in this project changed
    if echo "$CHANGED_FILES" | grep -q "^${PROJECT}/"; then
        echo "Changes detected in ${PROJECT} — running tests..."
        if [ -f "${PROJECT}/requirements.txt" ] && [ -d "${PROJECT}/tests" ]; then
            if ! python -m pytest "${PROJECT}/tests/" -q --tb=short; then
                echo -e "${RED}✗ Tests failed in ${PROJECT}${NC}"
                FAILED=1
            else
                echo -e "${GREEN}✓ Tests passed: ${PROJECT}${NC}"
            fi
        else
            echo -e "${YELLOW}⚠ No tests directory found for ${PROJECT} — skipping${NC}"
        fi
    fi
done

# Run tests for new folders too
for NEW_DIR in "hooks_and_startup" "securities_lending_optimizer" "stress_testing_framework"; do
    if echo "$CHANGED_FILES" | grep -q "^${NEW_DIR}/" && [ -d "${NEW_DIR}/tests" ]; then
        echo "Running tests for ${NEW_DIR}..."
        if ! python -m pytest "${NEW_DIR}/tests/" -q --tb=short; then
            echo -e "${RED}✗ Tests failed in ${NEW_DIR}${NC}"
            FAILED=1
        fi
    fi
done

if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}── pre-push FAILED — fix test failures before pushing ──────${NC}"
    exit 1
fi

echo -e "${GREEN}── pre-push passed ─────────────────────────────────────────${NC}"
exit 0
