#!/usr/bin/env bash
# =============================================================================
# pre-commit hook — runs on every `git commit`
# Checks: flake8 lint, mypy type-check (staged files only), secrets scan
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "── pre-commit hook ──────────────────────────────────────────"

# Identify staged Python files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
    echo -e "${GREEN}✓ No Python files staged — skipping lint/type checks${NC}"
else
    # ── 1. flake8 lint ────────────────────────────────────────────────────────
    echo "Running flake8..."
    if ! command -v flake8 &>/dev/null; then
        echo -e "${YELLOW}⚠ flake8 not found — skipping (install with: pip install flake8)${NC}"
    else
        if ! echo "$STAGED_PY" | xargs flake8 --max-line-length=120 --extend-ignore=E203,W503; then
            echo -e "${RED}✗ flake8 found issues. Fix before committing.${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ flake8 passed${NC}"
    fi

    # ── 2. mypy type-check ────────────────────────────────────────────────────
    echo "Running mypy..."
    if ! command -v mypy &>/dev/null; then
        echo -e "${YELLOW}⚠ mypy not found — skipping (install with: pip install mypy)${NC}"
    else
        if ! echo "$STAGED_PY" | xargs mypy --ignore-missing-imports --no-strict-optional; then
            echo -e "${RED}✗ mypy found type errors. Fix before committing.${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ mypy passed${NC}"
    fi
fi

# ── 3. Secrets scan ───────────────────────────────────────────────────────────
echo "Scanning for secrets in staged files..."
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM || true)

SECRET_PATTERNS=(
    "password\s*=\s*['\"][^'\"]{4,}"
    "secret\s*=\s*['\"][^'\"]{4,}"
    "api_key\s*=\s*['\"][^'\"]{8,}"
    "client_secret\s*=\s*['\"][^'\"]{8,}"
    "DATABRICKS_TOKEN\s*=\s*['\"][^'\"]{4,}"
    "Bearer\s+[A-Za-z0-9\-_]{20,}"
    "sk-[A-Za-z0-9]{20,}"
)

FOUND_SECRET=0
for FILE in $STAGED_ALL; do
    if [ -f "$FILE" ]; then
        for PATTERN in "${SECRET_PATTERNS[@]}"; do
            if git diff --cached "$FILE" | grep -iE "$PATTERN" &>/dev/null; then
                echo -e "${RED}✗ Possible secret detected in ${FILE} (pattern: ${PATTERN})${NC}"
                FOUND_SECRET=1
            fi
        done
    fi
done

if [ "$FOUND_SECRET" -eq 1 ]; then
    echo -e "${RED}✗ Remove secrets before committing. Use environment variables instead.${NC}"
    exit 1
fi

echo -e "${GREEN}✓ No secrets detected${NC}"
echo -e "${GREEN}── pre-commit passed ───────────────────────────────────────${NC}"
exit 0
