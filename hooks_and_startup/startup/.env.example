# =============================================================================
# .env.example — Copy this file to .env at the repository root and fill in
#                your actual values. NEVER commit the real .env file.
# =============================================================================

# ── PowerBI / Azure AD ────────────────────────────────────────────────────────
POWERBI_CLIENT_ID=your-azure-ad-app-client-id-here
POWERBI_CLIENT_SECRET=your-azure-ad-app-secret-here
POWERBI_TENANT_ID=your-azure-ad-tenant-id-here
POWERBI_WORKSPACE_ID=your-powerbi-workspace-guid-here

# ── Email Alerts (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your-smtp-password-here
ALERT_FROM=alerts@yourdomain.com
ALERT_EMAIL_RECIPIENTS=team@yourdomain.com,risk@yourdomain.com

# ── Microsoft Teams ───────────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-id/IncomingWebhook/...

# ── Databricks (optional) ─────────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-personal-access-token
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
